// ============ Document Templates (multi-type) ============
model DocumentTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  docType     String   // invoice | quotation | receipt | purchase_order | delivery_note | statement | credit_note
  config      String   @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, docType])
  @@index([tenantId])
}
// ============ Rewards System (tenant-customizable) ============
// Tenants can configure a points-based reward system where doctors/staff
// earn points for completing visits (service forms) and redeem them in
// a panel shop for rewards (gift cards, time off, merch, etc.).

model RewardConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  isEnabled       Boolean  @default(false)
  pointsPerVisit  Int      @default(10)    // points awarded when a service form is saved
  pointsLabel     String   @default("Nex Coins") // customizable label (default: Nex Coins — platform currency)
  shopName        String   @default("Rewards Shop") // customizable shop title
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RewardItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  pointsCost  Int                   // points required to redeem
  imageUrl    String?
  stock       Int      @default(-1) // -1 = unlimited, 0 = sold out, >0 = available
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions RewardRedemption[]

  @@index([tenantId])
}

model PointTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  type        String   // earned | spent | adjusted
  amount      Int      // positive for earned, negative for spent
  description String
  refType     String?  // encounter | redemption | admin_adjustment
  refId       String?
  createdAt   DateTime @default(now())

  @@index([tenantId, userId])
}

model RewardRedemption {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  itemId      String
  pointsCost  Int                   // snapshot of item cost at redemption time
  status      String   @default("pending") // pending | fulfilled | cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item        RewardItem @relation(fields: [itemId], references: [id])

  @@index([tenantId, userId])
}

// ============ Partner Shops (external merchants that accept points) ============
// Employees can browse partner shops, redeem items/vouchers, and pay with points.
// Flow: Employee generates QR → Shop owner scans → Employee confirms → points transfer.

model PartnerShop {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  logoUrl      String?
  category     String   @default("General") // e.g. Cafe, Pharmacy, Retail, Wellness
  ownerUserId  String   // the User who logs in as this shop's owner (scans QR codes)
  isActive     Boolean  @default(true)
  isGlobal     Boolean  @default(false) // when true, shop is visible to ALL tenants' employees (cross-tenant marketplace)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User     @relation(fields: [ownerUserId], references: [id])
  catalog      ShopCatalogItem[]
  redemptions  RedemptionCode[]

  @@index([tenantId])
  @@index([isGlobal])
}

model ShopCatalogItem {
  id            String   @id @default(cuid())
  tenantId      String
  shopId        String
  name          String
  description   String?
  rewardType    String   @default("voucher") // voucher | discount | freeGift | service
  rewardDetails String?  // e.g. "RM10 off", "Free coffee", "20% discount"
  pointsCost    Int
  imageUrl      String?
  stock         Int      @default(-1) // -1 = unlimited
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop          PartnerShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  redemptions   RedemptionCode[]

  @@index([tenantId, shopId])
}

model RedemptionCode {
  id            String   @id @default(cuid())
  tenantId      String
  code          String   @unique  // short human-readable code for manual entry
  token         String   @unique  // long token embedded in QR code
  employeeId    String   // the user who initiated the redemption
  shopId        String
  itemId        String
  pointsCost    Int                 // snapshot of item cost at redemption time
  status        String   @default("pending") // pending → scanned → confirmed → cancelled
  // pending: employee generated QR, waiting for shop owner to scan
  // scanned: shop owner scanned, waiting for employee to confirm
  // confirmed: employee confirmed → points transferred, reward unlocked
  // cancelled: either party cancelled before confirmation
  scannedAt     DateTime?
  scannedBy     String?  // userId of shop owner who scanned
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())

  shop          PartnerShop    @relation(fields: [shopId], references: [id])
  item          ShopCatalogItem @relation(fields: [itemId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, shopId])
  @@index([code])
}

// ============ Reward Tasks (tenant-configurable point-earning tasks) ============
// Admins can define different tasks that earn different point amounts.
// Trigger types:
//   visit_created  — auto-awarded when a service form is saved
//   monthly_bonus  — manually awarded by admin (e.g. Employee of the Month)
//   referral       — manually awarded when a referral is confirmed
//   custom         — any other admin-awarded task

model RewardTask {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  points      Int                   // points awarded for completing this task
  triggerType String   @default("manual") // visit_created | monthly_bonus | referral | custom | manual
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ============ Platform Settings (OWNER-only, cross-tenant) ============
// Controls the "redemption fee" — a percentage of points burned on every
// cross-tenant redemption to prevent point inflation in the circular economy.
//
// Flow: platform grants points → tenant rewards employee → employee spends
// at shop → shop owner rewards employee again → ... Without a burn mechanism,
// points accumulate indefinitely (inflation). The fee removes points from
// circulation on each cross-tenant transaction.
//
// Example: fee = 10%, employee redeems 100 pts at a global shop:
//   - Employee loses: 100 pts
//   - Shop owner gains: 90 pts
//   - Burned (removed from circulation): 10 pts

model PlatformSetting {
  id                  String   @id @default(cuid())
  key                 String   @unique
  value               String
  description         String?
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}
